  primaryclass = {cs, math},
  doi = {10.48550/arXiv.2402.09379},
  urldate = {2024-02-17},
  abstract = {We study the problem of approximating a matrix \${\textbackslash}mathbf\{A\}\$ with a matrix that has a fixed sparsity pattern (e.g., diagonal, banded, etc.), when \${\textbackslash}mathbf\{A\}\$ is accessed only by matrix-vector products. We describe a simple randomized algorithm that returns an approximation with the given sparsity pattern with Frobenius-norm error at most \$(1+{\textbackslash}varepsilon)\$ times the best possible error. When each row of the desired sparsity pattern has at most \$s\$ nonzero entries, this algorithm requires \$O(s/{\textbackslash}varepsilon)\$ non-adaptive matrix-vector products with \${\textbackslash}mathbf\{A\}\$. We also prove a matching lower-bound, showing that, for any sparsity pattern with \${\textbackslash}Theta(s)\$ nonzeros per row and column, any algorithm achieving \$(1+{\textbackslash}epsilon)\$ approximation requires \${\textbackslash}Omega(s/{\textbackslash}varepsilon)\$ matrix-vector products in the worst case. We thus resolve the matrix-vector product query complexity of the problem up to constant factors, even for the well-studied case of diagonal approximation, for which no previous lower bounds were known.},
  archiveprefix = {arxiv},
  keywords = {Computer Science - Data Structures and Algorithms,Mathematics - Numerical Analysis},
  file = {/Users/ethanepperly/Zotero/storage/8JN5IL7F/Amsel et al. - 2024 - Fixed-sparsity matrix approximation from matrix-vector products.pdf}
