@article{PVY17,
  title = {High-Dimensional Estimation with Geometric Constraints},
  author = {Plan, Y. and Vershynin, R. and Yudovina, E.},
  year = {2017},
  month = mar,
  journal = {Information and Inference: A Journal of the IMA},
  volume = {6},
  number = {1},
  pages = {1--40},
  issn = {2049-8764},
  doi = {10.1093/imaiai/iaw015},
  urldate = {2021-03-11},
  abstract = {Consider measuring a vector \$x {\textbackslash}in {\textbackslash}mathbb\{R\}\^{}n\$ through the inner product with several measurement vectors, \$a\_1, a\_2, {\textbackslash}ldots, a\_m\$. It is common in both signal processing and statistics to assume the linear response model \$y\_i = {\textbackslash}left{\textbackslash}langle\{a\_i\},\{x\}{\textbackslash}right{\textbackslash}rangle + {\textbackslash}varepsilon\_i\$, where \${\textbackslash}varepsilon\_i\$ is a noise term. However, in practice the precise relationship between the signal \$x\$ and the observations \$y\_i\$ may not follow the linear model, and in some cases it may not even be known. To address this challenge, in this article we propose a general model where it is only assumed that each observation\$y\_i\$may depend on\$a\_i\$only through\${\textbackslash}left{\textbackslash}langle\{a\_i\},\{x\}{\textbackslash}right{\textbackslash}rangle\$. We do not assume that the dependence is known. This is a form of the semiparametric-single index model, and it includes the linear model as well as many forms of the generalized linear model as special cases. We further assume that the signal \$x\$ has some structure, and we formulate this as a general assumption that \$x\$ belongs to some known (but arbitrary) feasible set \$K {\textbackslash}subseteq {\textbackslash}mathbb\{R\}\^{}n\$. We carefully detail the benefit of using the signal structure to improve estimation. The theory is based on the mean width of \$K\$, a geometric parameter which can be used to understand its effective dimension in estimation problems. We determine a simple, efficient two-step procedure for estimating the signal based on this model---a linear estimation followed by metric projection onto \$K\$. We give general conditions under which the estimator is minimax optimal up to a constant. This leads to the intriguing conclusion that in the high noise regime, an unknown nonlinearity in the observations does not significantly reduce one's ability to determine the signal, even when the nonlinearity may be non-invertible. Our results may be specialized to understand the effect of nonlinearities in compressed sensing.},
  file = {/Users/ethanepperly/Zotero/storage/XNZ4S8N2/Plan et al. - 2017 - High-dimensional estimation with geometric constra.pdf;/Users/ethanepperly/Zotero/storage/P3AEU7TA/2669845.html}
}

