@article{AIK21,
  title = {The {{Acrobatics}} of {{BQP}}},
  author = {Aaronson, Scott and Ingram, DeVon and Kretschmer, William},
  year = {2021},
  month = nov,
  journal = {arXiv:2111.10409 [quant-ph]},
  eprint = {2111.10409},
  primaryclass = {quant-ph},
  urldate = {2021-11-23},
  abstract = {We show that, in the black-box setting, the behavior of quantum polynomial-time (\${\textbackslash}mathsf\{BQP\}\$) can be remarkably decoupled from that of classical complexity classes like \${\textbackslash}mathsf\{NP\}\$. Specifically: -There exists an oracle relative to which \${\textbackslash}mathsf\{NP\^{}\{BQP\}\}{\textbackslash}not{\textbackslash}subset{\textbackslash}mathsf\{BQP\^{}\{PH\}\}\$, resolving a 2005 problem of Fortnow. As a corollary, there exists an oracle relative to which \${\textbackslash}mathsf\{P\}={\textbackslash}mathsf\{NP\}\$ but \${\textbackslash}mathsf\{BQP\}{\textbackslash}neq{\textbackslash}mathsf\{QCMA\}\$. -Conversely, there exists an oracle relative to which \${\textbackslash}mathsf\{BQP\^{}\{NP\}\}{\textbackslash}not{\textbackslash}subset{\textbackslash}mathsf\{PH\^{}\{BQP\}\}\$. -Relative to a random oracle, \${\textbackslash}mathsf\{PP\}={\textbackslash}mathsf\{PostBQP\}\$ is not contained in the "\${\textbackslash}mathsf\{QMA\}\$ hierarchy" \${\textbackslash}mathsf\{QMA\}\^{}\{{\textbackslash}mathsf\{QMA\}\^{}\{{\textbackslash}mathsf\{QMA\}\^{}\{{\textbackslash}cdots\}\}\}\$, and more generally \${\textbackslash}mathsf\{PP\}{\textbackslash}not{\textbackslash}subset ({\textbackslash}mathsf\{MIP\}\^{}*)\^{}\{({\textbackslash}mathsf\{MIP\}\^{}*)\^{}\{({\textbackslash}mathsf\{MIP\}\^{}*)\^{}\{{\textbackslash}cdots\}\}\}\$ (!), despite the fact that \${\textbackslash}mathsf\{MIP\}\^{}*={\textbackslash}mathsf\{RE\}\$ in the unrelativized world. This result shows that there is no black-box quantum analogue of Stockmeyer's approximate counting algorithm. -Relative to a random oracle, \${\textbackslash}mathsf\{{\textbackslash}Sigma\}\_\{k+1\}\^{}{\textbackslash}mathsf\{P\}{\textbackslash}not{\textbackslash}subset{\textbackslash}mathsf\{BQP\}\^{}\{{\textbackslash}mathsf\{{\textbackslash}Sigma\}\_\{k\}\^{}{\textbackslash}mathsf\{P\}\}\$ for every \$k\$. -There exists an oracle relative to which \${\textbackslash}mathsf\{BQP\}={\textbackslash}mathsf\{P\^{}\{{\textbackslash}\# P\}\}\$ and yet \${\textbackslash}mathsf\{PH\}\$ is infinite. -There exists an oracle relative to which \${\textbackslash}mathsf\{P\}={\textbackslash}mathsf\{NP\}{\textbackslash}neq{\textbackslash}mathsf\{BQP\}={\textbackslash}mathsf\{P\^{}\{{\textbackslash}\# P\}\}\$. To achieve these results, we build on the 2018 achievement by Raz and Tal of an oracle relative to which \${\textbackslash}mathsf\{BQP\}{\textbackslash}not {\textbackslash}subset {\textbackslash}mathsf\{PH\}\$, and associated results about the Forrelation problem. We also introduce new tools that might be of independent interest. These include a "quantum-aware" version of the random restriction method, a concentration theorem for the block sensitivity of \${\textbackslash}mathsf\{AC\^{}0\}\$ circuits, and a (provable) analogue of the Aaronson-Ambainis Conjecture for sparse oracles.},
  archiveprefix = {arxiv},
  keywords = {Computer Science - Computational Complexity,Quantum Physics},
  file = {/Users/ethanepperly/Zotero/storage/YW2UVMZK/Aaronson et al. - 2021 - The Acrobatics of BQP.pdf}
