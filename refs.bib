  urldate = {2021-09-23},
  abstract = {This paper is concerned with two improved variants of the Hutch++ algorithm for estimating the trace of a square matrix, implicitly given through matrix-vector products. Hutch++ combines randomized low-rank approximation in a first phase with stochastic trace estimation in a second phase. In turn, Hutch++ only requires \$O{\textbackslash}left({\textbackslash}varepsilon\^{}\{-1\}{\textbackslash}right)\$ matrix-vector products to approximate the trace within a relative error \${\textbackslash}varepsilon\$ with high probability. This compares favorably with the \$O{\textbackslash}left({\textbackslash}varepsilon\^{}\{-2\}{\textbackslash}right)\$ matrix-vector products needed when using stochastic trace estimation alone. In Hutch++, the number of matrix-vector products is fixed a priori and distributed in a prescribed fashion among the two phases. In this work, we derive an adaptive variant of Hutch++, which outputs an estimate of the trace that is within some prescribed error tolerance with a controllable failure probability, while splitting the matrix-vector products in a near-optimal way among the two phases. For the special case of symmetric positive semi-definite matrix, we present another variant of Hutch++, called Nystr{\textbackslash}"om++, which utilizes the so called Nystr{\textbackslash}"om approximation and requires only one pass over the matrix, as compared to two passes with Hutch++. We extend the analysis of Hutch++ to Nystr{\textbackslash}"om++. Numerical experiments demonstrate the effectiveness of our two new algorithms.},
  archiveprefix = {arxiv},
  keywords = {65C05 65F30 68W20 68W25 68W27 68W40,Mathematics - Numerical Analysis},
  file = {/Users/ethanepperly/Zotero/storage/2XNXQKIZ/Persson et al. - 2021 - Improved variants of the Hutch++ algorithm for trace estimation.pdf}
}

