  abstract = {We present a sublinear query algorithm for outputting a near-optimal low-rank approximation to any positive semidefinite Toeplitz matrix \$T {\textbackslash}in {\textbackslash}mathbb\{R\}\^{}\{d {\textbackslash}times d\}\$. In particular, for any integer rank \$k {\textbackslash}leq d\$ and \${\textbackslash}epsilon,{\textbackslash}delta {$>$} 0\$, our algorithm makes \${\textbackslash}tilde\{O\} {\textbackslash}left (k\^{}2 {\textbackslash}cdot {\textbackslash}log(1/{\textbackslash}delta) {\textbackslash}cdot {\textbackslash}text\{poly\}(1/{\textbackslash}epsilon) {\textbackslash}right )\$ queries to the entries of \$T\$ and outputs a rank \${\textbackslash}tilde\{O\} {\textbackslash}left (k {\textbackslash}cdot {\textbackslash}log(1/{\textbackslash}delta)/{\textbackslash}epsilon{\textbackslash}right )\$ matrix \${\textbackslash}tilde\{T\} {\textbackslash}in {\textbackslash}mathbb\{R\}\^{}\{d {\textbackslash}times d\}\$ such that \${\textbackslash}{\textbar} T - {\textbackslash}tilde\{T\}{\textbackslash}{\textbar}\_F {\textbackslash}leq (1+{\textbackslash}epsilon) {\textbackslash}cdot {\textbackslash}{\textbar}T-T\_k{\textbackslash}{\textbar}\_F + {\textbackslash}delta {\textbackslash}{\textbar}T{\textbackslash}{\textbar}\_F\$. Here, \${\textbackslash}{\textbar}{\textbackslash}cdot{\textbackslash}{\textbar}\_F\$ is the Frobenius norm and \$T\_k\$ is the optimal rank-\$k\$ approximation to \$T\$, given by projection onto its top \$k\$ eigenvectors. \${\textbackslash}tilde\{O\}({\textbackslash}cdot)\$ hides \${\textbackslash}text\{polylog\}(d) \$ factors. Our algorithm is {\textbackslash}emph\{structure-preserving\}, in that the approximation \${\textbackslash}tilde\{T\}\$ is also Toeplitz. A key technical contribution is a proof that any positive semidefinite Toeplitz matrix in fact has a near-optimal low-rank approximation which is itself Toeplitz. Surprisingly, this basic existence result was not previously known. Building on this result, along with the well-established off-grid Fourier structure of Toeplitz matrices [Cybenko'82], we show that Toeplitz \${\textbackslash}tilde\{T\}\$ with near optimal error can be recovered with a small number of random queries via a leverage-score-based off-grid sparse Fourier sampling scheme.},
  archiveprefix = {arxiv},
  keywords = {Computer Science - Data Structures and Algorithms,Mathematics - Numerical Analysis},
  file = {/Users/ethanepperly/Zotero/storage/5GJKNCUZ/Kapralov et al. - 2022 - Toeplitz Low-Rank Approximation with Sublinear Query Complexity.pdf}
}

