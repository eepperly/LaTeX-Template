  author = {Minev, Z. K. and Mundhada, S. O. and Shankar, S. and Reinhold, P. and {Guti{\'e}rrez-J{\'a}uregui}, R. and Schoelkopf, R. J. and Mirrahimi, M. and Carmichael, H. J. and Devoret, M. H.},
  year = {2019},
