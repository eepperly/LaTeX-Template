  address = {Berlin, Heidelberg},
  doi = {10.1007/11841036_29},
  abstract = {Much recent work in the theoretical computer science, linear algebra, and machine learning has considered matrix decompositions of the following form: given an m {\texttimes}n matrix A, decompose it as a product of three matrices, C, U, and R, where C consists of a small number of columns of A, R consists of a small number of rows of A, and U is a small carefully constructed matrix that guarantees that the product CUR is ``close'' to A. Applications of such decompositions include the computation of matrix ``sketches'', speeding up kernel-based statistical learning, preserving sparsity in low-rank matrix representation, and improved interpretability of data analysis methods. Our main result is a randomized, polynomial algorithm which, given as input an m {\texttimes}n matrix A, returns as output matrices C, U, R such that {\textbardbl}{$A-CUR$}{\textbardbl}{$F\leq$}(1+{$\in$}){\textbardbl}{$A-Ak$}{\textbardbl}{$F$}{\textbardbl}A-CUR{\textbardbl}F{$\leq$}(1+{$\epsilon$}){\textbardbl}A-Ak{\textbardbl}F{\textbackslash}{\textbar}\{A-CUR\}{\textbackslash}{\textbar}\_F {\textbackslash}leq (1+{\textbackslash}epsilon){\textbackslash}{\textbar}\{A-A\_k\}{\textbackslash}{\textbar}\_F with probability at least 1--{$\delta$}. Here, A k is the ``best'' rank-k approximation (provided by truncating the Singular Value Decomposition of A), and {\textbar}{\textbar}X{\textbar}{\textbar} F is the Frobenius norm of the matrix X. The number of columns in C and rows in R is a low-degree polynomial in k, 1/{$\varepsilon$}, and log(1/{$\delta$}). Our main result is obtained by an extension of our recent relative error approximation algorithm for {$\ell$}2 regression from overconstrained problems to general {$\ell$}2 regression problems. Our algorithm is simple, and it takes time of the order of the time needed to compute the top k right singular vectors of A. In addition, it samples the columns and rows of A via the method of ``subspace sampling,'' so-named since the sampling probabilities depend on the lengths of the rows of the top singular vectors, and since they ensure that we capture entirely a certain subspace of interest.},
