@misc{TJS+24,
  title = {{{CompactifAI}}: {{Extreme Compression}} of {{Large Language Models}} Using {{Quantum-Inspired Tensor Networks}}},
  shorttitle = {{{CompactifAI}}},
  author = {Tomut, Andrei and Jahromi, Saeed S. and Singh, Sukhbinder and Ishtiaq, Faysal and Mu{\~n}oz, Cesar and Bajaj, Prabdeep Singh and Elborady, Ali and {del Bimbo}, Gianni and Alizadeh, Mehrazin and Montero, David and {Martin-Ramiro}, Pablo and Ibrahim, Muhammad and Alaoui, Oussama Tahiri and Malcolm, John and Mugel, Samuel and Orus, Roman},
  year = {2024},
