@article{HLB+20,
  title = {A Non-Orthogonal Variational Quantum Eigensolver},
  author = {Huggins, William J. and Lee, Joonho and Baek, Unpil and O'Gorman, Bryan and Whaley, K. Birgitta},
  year = {2020},
