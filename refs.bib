@article{HL83,
  title = {Explicit {{Hilbert-space}} Representations of Atomic and Molecular Photoabsorption Spectra: {{Computational}} Studies of {{Stieltjes-Tchebycheff}} Functions},
  shorttitle = {Explicit {{Hilbert-space}} Representations of Atomic and Molecular Photoabsorption Spectra},
  author = {Hermann, M. R. and Langhoff, P. W.},
  year = {1983},
