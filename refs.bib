  file = {/Users/ethanepperly/Zotero/storage/V3TCKHEG/Nakatsukasa et al. - 2012 - Mysteries around the graph Laplacian eigenvalue 4.pdf}
}

@misc{NSW22,
  title = {Testing {{Positive Semidefiniteness Using Linear Measurements}}},
  author = {Needell, Deanna and Swartworth, William and Woodruff, David P.},
  year = {2022},
