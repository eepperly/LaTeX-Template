@article{Lei05,
  title = {The Historical Bases of the {{Rayleigh}} and {{Ritz}} Methods},
  author = {Leissa, A. W.},
  year = {2005},
  month = nov,
  journal = {Journal of Sound and Vibration},
  volume = {287},
  number = {4},
  pages = {961--978},
  issn = {0022-460X},
  doi = {10.1016/j.jsv.2004.12.021},
  urldate = {2022-09-11},
  abstract = {Rayleigh's classical book Theory of Sound was first published in 1877. In it are many examples of calculating fundamental natural frequencies of free vibration of continuum systems (strings, bars, beams, membranes, plates) by assuming the mode shape, and setting the maximum values of potential and kinetic energy in a cycle of motion equal to each other. This procedure is well known as ``Rayleigh's Method.'' In 1908, Ritz laid out his famous method for determining frequencies and mode shapes, choosing multiple admissible displacement functions, and minimizing a functional involving both potential and kinetic energies. He then demonstrated it in detail in 1909 for the completely free square plate. In 1911, Rayleigh wrote a paper congratulating Ritz on his work, but stating that he himself had used Ritz's method in many places in his book and in another publication. Subsequently, hundreds of research articles and many books have appeared which use the method, some calling it the ``Ritz method'' and others the ``Rayleigh--Ritz method.'' The present article examines the method in detail, as Ritz presented it, and as Rayleigh claimed to have used it. It concludes that, although Rayleigh did solve a few problems which involved minimization of a frequency, these solutions were not by the straightforward, direct method presented by Ritz and used subsequently by others. Therefore, Rayleigh's name should not be attached to the method.},
  langid = {english},
  file = {/Users/ethanepperly/Zotero/storage/6JA9EYLZ/Leissa - 2005 - The historical bases of the Rayleigh and Ritz meth.pdf;/Users/ethanepperly/Zotero/storage/ITKGXFPL/S0022460X05000362.html}
}

@article{LEM19,
  title = {Bootstrapping the {{Operator Norm}} in {{High Dimensions}}: {{Error Estimation}} for {{Covariance Matrices}} and {{Sketching}}},
  shorttitle = {Bootstrapping the {{Operator Norm}} in {{High Dimensions}}},
  author = {Lopes, Miles E. and Erichson, N. Benjamin and Mahoney, Michael W.},
  year = {2019},
  month = sep,
  journal = {arXiv:1909.06120 [cs, math, stat]},
  eprint = {1909.06120},
  primaryclass = {cs, math, stat},
  urldate = {2021-01-29},
  abstract = {Although the operator (spectral) norm is one of the most widely used metrics for covariance estimation, comparatively little is known about the fluctuations of error in this norm. To be specific, let \${\textbackslash}hat{\textbackslash}Sigma\$ denote the sample covariance matrix of \$n\$ observations in \${\textbackslash}mathbb\{R\}\^{}p\$ that arise from a population matrix \${\textbackslash}Sigma\$, and let \$T\_n={\textbackslash}sqrt\{n\}{\textbackslash}{\textbar}{\textbackslash}hat{\textbackslash}Sigma-{\textbackslash}Sigma{\textbackslash}{\textbar}\_\{{\textbackslash}text\{op\}\}\$. In the setting where the eigenvalues of \${\textbackslash}Sigma\$ have a decay profile of the form \${\textbackslash}lambda\_j({\textbackslash}Sigma){\textbackslash}asymp j\^{}\{-2{\textbackslash}beta\}\$, we analyze how well the bootstrap can approximate the distribution of \$T\_n\$. Our main result shows that up to factors of \${\textbackslash}log(n)\$, the bootstrap can approximate the distribution of \$T\_n\$ at the dimension-free rate of \$n\^{}\{-{\textbackslash}frac\{{\textbackslash}beta-1/2\}\{6{\textbackslash}beta+4\}\}\$, with respect to the Kolmogorov metric. Perhaps surprisingly, a result of this type appears to be new even in settings where \$p{$<$} n\$. More generally, we discuss the consequences of this result beyond covariance matrices and show how the bootstrap can be used to estimate the errors of sketching algorithms in randomized numerical linear algebra (RandNLA). An illustration of these ideas is also provided with a climate data example.},
  archiveprefix = {arxiv},
  langid = {english},
  keywords = {Mathematics - Numerical Analysis,Mathematics - Statistics Theory,Statistics - Methodology},
  file = {/Users/ethanepperly/Zotero/storage/U5A7ZLHE/Lopes et al. - 2019 - Bootstrapping the Operator Norm in High Dimensions.pdf}
}

