@article{QKPW20,
  title = {Lift \& {{Learn}}: {{Physics-informed}} Machine Learning for Large-Scale Nonlinear Dynamical Systems},
  shorttitle = {Lift \& {{Learn}}},
  author = {Qian, Elizabeth and Kramer, Boris and Peherstorfer, Benjamin and Willcox, Karen},
