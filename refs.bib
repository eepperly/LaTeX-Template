  month = nov,
  journal = {arXiv:2111.01848 [cs, math]},
  eprint = {2111.01848},
  primaryclass = {cs, math},
  urldate = {2021-11-04},
  abstract = {In this paper we obtain improved iteration complexities for solving \${\textbackslash}ell\_p\$ regression. We provide methods which given any full-rank \${\textbackslash}mathbf\{A\} {\textbackslash}in {\textbackslash}mathbb\{R\}\^{}\{n {\textbackslash}times d\}\$ with \$n {\textbackslash}geq d\$, \$b {\textbackslash}in {\textbackslash}mathbb\{R\}\^{}n\$, and \$p {\textbackslash}geq 2\$ solve \${\textbackslash}min\_\{x {\textbackslash}in {\textbackslash}mathbb\{R\}\^{}d\} {\textbackslash}left{\textbackslash}{\textbar}{\textbackslash}mathbf\{A\} x - b{\textbackslash}right{\textbackslash}{\textbar}\_p\$ to high precision in time dominated by that of solving \${\textbackslash}widetilde\{O\}\_p(d\^{}\{{\textbackslash}frac\{p-2\}\{3p-2\}\})\$ linear systems in \${\textbackslash}mathbf\{A\}\^{}{\textbackslash}top {\textbackslash}mathbf\{D\} {\textbackslash}mathbf\{A\}\$ for positive diagonal matrices \${\textbackslash}mathbf\{D\}\$. This improves upon the previous best iteration complexity of \${\textbackslash}widetilde\{O\}\_p(n\^{}\{{\textbackslash}frac\{p-2\}\{3p-2\}\})\$ (Adil, Kyng, Peng, Sachdeva 2019). As a corollary, we obtain an \${\textbackslash}widetilde\{O\}(d\^{}\{1/3\}{\textbackslash}epsilon\^{}\{-2/3\})\$ iteration complexity for approximate \${\textbackslash}ell\_{\textbackslash}infty\$ regression. Further, for \$q {\textbackslash}in (1, 2]\$ and dual norm \$q = p/(p-1)\$ we provide an algorithm that solves \${\textbackslash}ell\_q\$ regression in \${\textbackslash}widetilde\{O\}(d\^{}\{{\textbackslash}frac\{p-2\}\{2p-2\}\})\$ iterations. To obtain this result we analyze row reweightings (closely inspired by \${\textbackslash}ell\_p\$-norm Lewis weights) which allow a closer connection between \${\textbackslash}ell\_2\$ and \${\textbackslash}ell\_p\$ regression. We provide adaptations of two different iterative optimization frameworks which leverage this connection and yield our results. The first framework is based on iterative refinement and multiplicative weights based width reduction and the second framework is based on highly smooth acceleration. Both approaches yield \${\textbackslash}widetilde\{O\}\_p(d\^{}\{{\textbackslash}frac\{p-2\}\{3p-2\}\})\$ iteration methods but the second has a polynomial dependence on \$p\$ (as opposed to the exponential dependence of the first algorithm) and provides a new alternative to the previous state-of-the-art methods for \${\textbackslash}ell\_p\$ regression for large \$p\$.},
  archiveprefix = {arxiv},
  keywords = {Computer Science - Data Structures and Algorithms,Mathematics - Optimization and Control},
  file = {/Users/ethanepperly/Zotero/storage/I7FC4LNJ/Jambulapati et al. - 2021 - Improved Iteration Complexities for Overconstrained $p$-Norm Regression.pdf}
}

@article{JM19,
  title = {Distances {{Between Random Orthogonal Matrices}} and {{Independent Normals}}},
  author = {Jiang, Tiefeng and Ma, Yutao},
  year = {2019},
  journal = {Transactions of the American Mathematical Society},
  volume = {372},
