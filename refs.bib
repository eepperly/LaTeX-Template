  keywords = {Computer Science - Data Structures and Algorithms},
  file = {/Users/ethanepperly/Zotero/storage/V4GEC745/Meyer et al. - 2022 - Near-Linear Sample Complexity for $L_p$ Polynomial Regression.pdf}
}

@misc{MMMW21,
