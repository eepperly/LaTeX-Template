  keywords = {42A15 65D32 94A20,Mathematics - Numerical Analysis},
  file = {/Users/ethanepperly/Zotero/storage/AMTKTGKZ/Yu and Townsend - 2022 - On the stability of unevenly spaced samples for interpolation and quadrature.pdf}
}

