  abstract = {Let (A,B) be a definite pair of n {\texttimes}n Hermitian matrices. That is, {\textbar}x\textsuperscript{*}Ax{\textbar} + {\textbar}x\textsuperscript{*}Bx{\textbar} {$\neq$}0 for all non-zero vectors x {$\in^n$}. It is possible to find an n {\texttimes}n non-singular matrix X with unit columns such that  X\textsuperscript{*} (A + iB) X = diag({$\alpha_1$} + i {$\beta_1$}, , {$\alpha_n$} + i {$\beta_n$})  where {$\alpha$}\textsubscript{j} and {$\beta$}\textsubscript{j} are real numbers. We call the pairs ({$\alpha$}\textsubscript{j}, {$\beta$}\textsubscript{j}) \emph{normalized generalized eigenvalues} of the definite pair (A, B). These pairs have not been studied previously. We rework the perturbation theory for the eigenvalues and eigenvectors of the definite generalized eigenvalue problem {$\beta$}Ax = {$\alpha$}Bx in terms of these normalized generalized eigenvalues and show that they play a crucial rule in obtaining the best possible perturbation bounds. In particular, in existing perturbation bounds, one can replace most instances of the Crawford number [ c(A,B) = \{ {\textbar}x\vphantom\}\textsuperscript{*} (A + iB)x{\textbar}: x {$\in^n$}, x\textsuperscript{*}x = 1 \vphantom\{\} ] with the larger quantity [ d = \{ {\textbar}{$\alpha\vphantom\}$}\textsubscript{j} + i{$\beta$}\textsubscript{j}{\textbar}: j = 1, {\dots}, n \vphantom\{\}. ] This results in bounds that can be stronger by an arbitrarily large factor. We also give a new measure of the separation of the jth eigenvalue from the kth: [ {\textbar}({$\alpha$}\textsubscript{j} + i {$\beta$}\textsubscript{j}) (({$\alpha$}\textsubscript{j} + i {$\beta$}\textsubscript{j}) - ({$\alpha_k$} + i {$\beta_k$})){\textbar} . ] This asymmetric measure is entirely new, and again results in bounds that can be arbitrarily stronger than the existing bounds. We show that all but one of our bounds are attainable. We also show that the Crawford number is the infimum of the distance from a definite pencil, \emph{a fortiori} diagonalizable, to a non-diagonalizable pair.},
  file = {/Users/ethanepperly/Zotero/storage/HF77ZJAD/Mathias and Li - 2004 - The definite generalized eigenvalue problem A new.pdf}
}

@inproceedings{MM15,
