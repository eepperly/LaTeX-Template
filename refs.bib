  primaryclass = {quant-ph},
  urldate = {2021-07-30},
  abstract = {The exponential speedups promised by Hamiltonian simulation on a quantum computer depends crucially on structure in both the Hamiltonian \${\textbackslash}hat\{H\}\$, and the quantum circuit \${\textbackslash}hat\{U\}\$ that encodes its description. In the quest to better approximate time-evolution \$e\^{}\{-i{\textbackslash}hat\{H\}t\}\$ with error \${\textbackslash}epsilon\$, we motivate a systematic approach to understanding and exploiting structure, in a setting where Hamiltonians are encoded as measurement operators of unitary circuits \${\textbackslash}hat\{U\}\$ for generalized measurement. This allows us to define a {\textbackslash}emph\{uniform spectral amplification\} problem on this framework for expanding the spectrum of encoded Hamiltonian with exponentially small distortion. We present general solutions to uniform spectral amplification in a hierarchy where factoring \${\textbackslash}hat\{U\}\$ into \$n=1,2,3\$ unitary oracles represents increasing structural knowledge of the encoding. Combined with structural knowledge of the Hamiltonian, specializing these results allow us simulate time-evolution by \$d\$-sparse Hamiltonians using \${\textbackslash}mathcal\{O\}{\textbackslash}left(t(d {\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{{\textbackslash}text\{max\}\}{\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{1\})\^{}\{1/2\}{\textbackslash}log\{(t{\textbackslash}{\textbar}{\textbackslash}hat\{H\}{\textbackslash}{\textbar}/{\textbackslash}epsilon)\}{\textbackslash}right)\$ queries, where \${\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}{\textbackslash}le {\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_1{\textbackslash}le d{\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{{\textbackslash}text\{max\}\}\$. Up to logarithmic factors, this is a polynomial improvement upon prior art using \${\textbackslash}mathcal\{O\}{\textbackslash}left(td{\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{{\textbackslash}text\{max\}\}+{\textbackslash}frac\{{\textbackslash}log\{(1/{\textbackslash}epsilon)\}\}\{{\textbackslash}log{\textbackslash}log\{(1/{\textbackslash}epsilon)\}\}{\textbackslash}right)\$ or \${\textbackslash}mathcal\{O\}(t\^{}\{3/2\}(d {\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{{\textbackslash}text\{max\}\}{\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{1\}{\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}/{\textbackslash}epsilon)\^{}\{1/2\})\$ queries. In the process, we also prove a matching lower bound of \${\textbackslash}Omega(t(d{\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{{\textbackslash}text\{max\}\}{\textbackslash}{\textbar}{\textbackslash}hat H{\textbackslash}{\textbar}\_\{1\})\^{}\{1/2\})\$ queries, present a distortion-free generalization of spectral gap amplification, and an amplitude amplification algorithm that performs multiplication on unknown state amplitudes.},
  archiveprefix = {arxiv},
  keywords = {Quantum Physics},
