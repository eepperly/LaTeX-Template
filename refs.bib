@inproceedings{PW11,
  title = {(1 + Eps)-{{Approximate Sparse Recovery}}},
  booktitle = {2011 {{IEEE}} 52nd {{Annual Symposium}} on {{Foundations}} of {{Computer Science}}},
  author = {Price, E. and Woodruff, D. P.},
  year = {2011},
