  publisher = {arXiv},
  urldate = {2022-11-08},
  abstract = {We study the problem of testing identity against a given distribution with a focus on the high confidence regime. More precisely, given samples from an unknown distribution \$p\$ over \$n\$ elements, an explicitly given distribution \$q\$, and parameters \$0{$<$} {\textbackslash}epsilon, {\textbackslash}delta {$<$} 1\$, we wish to distinguish, \{{\textbackslash}em with probability at least \$1-{\textbackslash}delta\$\}, whether the distributions are identical versus \${\textbackslash}varepsilon\$-far in total variation distance. Most prior work focused on the case that \${\textbackslash}delta = {\textbackslash}Omega(1)\$, for which the sample complexity of identity testing is known to be \${\textbackslash}Theta({\textbackslash}sqrt\{n\}/{\textbackslash}epsilon\^{}2)\$. Given such an algorithm, one can achieve arbitrarily small values of \${\textbackslash}delta\$ via black-box amplification, which multiplies the required number of samples by \${\textbackslash}Theta({\textbackslash}log(1/{\textbackslash}delta))\$. We show that black-box amplification is suboptimal for any \${\textbackslash}delta = o(1)\$, and give a new identity tester that achieves the optimal sample complexity. Our new upper and lower bounds show that the optimal sample complexity of identity testing is {\textbackslash}[ {\textbackslash}Theta{\textbackslash}left( {\textbackslash}frac\{1\}\{{\textbackslash}epsilon\^{}2\}{\textbackslash}left({\textbackslash}sqrt\{n {\textbackslash}log(1/{\textbackslash}delta)\} + {\textbackslash}log(1/{\textbackslash}delta) {\textbackslash}right){\textbackslash}right) {\textbackslash}] for any \$n, {\textbackslash}varepsilon\$, and \${\textbackslash}delta\$. For the special case of uniformity testing, where the given distribution is the uniform distribution \$U\_n\$ over the domain, our new tester is surprisingly simple: to test whether \$p = U\_n\$ versus \$d\_\{{\textbackslash}mathrm TV\}(p, U\_n) {\textbackslash}geq {\textbackslash}varepsilon\$, we simply threshold \$d\_\{{\textbackslash}mathrm TV\}({\textbackslash}widehat\{p\}, U\_n)\$, where \${\textbackslash}widehat\{p\}\$ is the empirical probability distribution. The fact that this simple "plug-in" estimator is sample-optimal is surprising, even in the constant \${\textbackslash}delta\$ case. Indeed, it was believed that such a tester would not attain sublinear sample complexity even for constant values of \${\textbackslash}varepsilon\$ and \${\textbackslash}delta\$.},
  archiveprefix = {arxiv},
  keywords = {Computer Science - Data Structures and Algorithms,Computer Science - Information Theory,Computer Science - Machine Learning,Mathematics - Statistics Theory},
