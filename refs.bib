  abstract = {Matrix trace estimation is ubiquitous in machine learning applications and has traditionally relied on Hutchinson's method, which requires \$O({\textbackslash}log(1/{\textbackslash}delta)/{\textbackslash}epsilon\^{}2)\$ matrix-vector product queries to achieve a \$(1 {\textbackslash}pm {\textbackslash}epsilon)\$-multiplicative approximation to \${\textbackslash}text\{tr\}(A)\$ with failure probability \${\textbackslash}delta\$ on positive-semidefinite input matrices \$A\$. Recently, the Hutch++ algorithm was proposed, which reduces the number of matrix-vector queries from \$O(1/{\textbackslash}epsilon\^{}2)\$ to the optimal \$O(1/{\textbackslash}epsilon)\$, and the algorithm succeeds with constant probability. However, in the high probability setting, the non-adaptive Hutch++ algorithm suffers an extra \$O({\textbackslash}sqrt\{{\textbackslash}log(1/{\textbackslash}delta)\})\$ multiplicative factor in its query complexity. Non-adaptive methods are important, as they correspond to sketching algorithms, which are mergeable, highly parallelizable, and provide low-memory streaming algorithms as well as low-communication distributed protocols. In this work, we close the gap between non-adaptive and adaptive algorithms, showing that even non-adaptive algorithms can achieve \$O({\textbackslash}sqrt\{{\textbackslash}log(1/{\textbackslash}delta)\}/{\textbackslash}epsilon + {\textbackslash}log(1/{\textbackslash}delta))\$ matrix-vector products. In addition, we prove matching lower bounds demonstrating that, up to a \${\textbackslash}log {\textbackslash}log(1/{\textbackslash}delta)\$ factor, no further improvement in the dependence on \${\textbackslash}delta\$ or \${\textbackslash}epsilon\$ is possible by any non-adaptive algorithm. Finally, our experiments demonstrate the superior performance of our sketch over the adaptive Hutch++ algorithm, which is less parallelizable, as well as over the non-adaptive Hutchinson's method.},
  archiveprefix = {arxiv},
  keywords = {Computer Science - Data Structures and Algorithms,Mathematics - Numerical Analysis},
  file = {/Users/ethanepperly/Zotero/storage/Q77HW9DJ/Jiang et al. - 2021 - Optimal Sketching for Trace Estimation.pdf}
}

